PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=occre_app

JWT_SECRET=genera_un_secreto_seguro_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Seed data (opcional)
SEED_EMAIL=owen@occre.app
SEED_PASSWORD=owen12345
SEED_FIRST_NAME=Owen
SEED_LAST_NAME=OCCRE

# Email (SMTP para recuperación de contraseña)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@occre.gov.co

# Frontend URL (para enlaces de recuperación y CORS)
# Demo remota: usa '*' para permitir cualquier origen (solo pruebas temporales)
FRONTEND_URL=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
